# --- LiveKit ---
# Generate with: docker run --rm livekit/livekit-server generate-keys
LIVEKIT_API_KEY=APIchangeme
LIVEKIT_API_SECRET=changeme-64-char-random
LIVEKIT_WS_URL=wss://meet.witysk.org/rtc

# Webhook key (use same value as LIVEKIT_API_KEY unless you want per-webhook keys)
LIVEKIT_WEBHOOK_KEY=APIchangeme

# Public IP of the host (set explicitly for reliability behind NAT)
LIVEKIT_EXTERNAL_IP=203.0.113.10

# --- meeting-api ---
MEETING_API_PORT=8080
DATABASE_URL=sqlite:////var/lib/meet/meet.db
RECORDINGS_DIR=/var/lib/meet/recordings
# Where playlist MP4s are stored, as <PLAYBACK_DIR>/<meeting_id>/<item_id>.mp4.
# Must be bind-mounted into meeting-api at this same absolute path, because
# playback_items.file_path stores absolute paths. Production points this at a
# dedicated volume: /mnt/video1/meetvideos
PLAYBACK_DIR=/var/lib/meet/playback
RECORDING_RETENTION_DAYS=30

# --- JWT / auth bridge ---
# HS256 shared secret — MUST match one.witysk.org's SECRET_KEY so tokens are valid across both.
JWT_SECRET_KEY=set-to-same-value-as-one-witysk-secret-key
JWT_ALGORITHM=HS256
JWT_AUDIENCE=meet.witysk.org

# Reserved for future DPoP/JWKS migration (currently unused):
# ONE_WITYSK_JWKS_URL=https://one.witysk.org/.well-known/jwks.json
# ONE_WITYSK_ISSUER=https://one.witysk.org
# DPOP_REPLAY_TTL_SECONDS=300

# --- coturn reuse (short-lived TURN creds per RFC 5766) ---
TURN_HOST=turn.witysk.org
TURN_STATIC_AUTH_SECRET=set-to-same-value-as-coturn-static-auth-secret
TURN_TTL_SECONDS=3600

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Rate limiting ---
ANON_TOKEN_RATE_PER_HOUR=30

# --- Frontend ---
# URL users visit; used for CORS and generated join links
PUBLIC_URL=https://meet.witysk.org
