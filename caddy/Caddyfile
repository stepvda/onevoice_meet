{
    # Global options.
    email stephane@stepvda.com
}

meet.witysk.org {
    encode zstd gzip

    # Path-independent security headers. Per-path framing rules
    # (X-Frame-Options + CSP) live inside the relevant handle blocks
    # below because mixing path-matched and unmatched `header` directives
    # at the site-block level causes Caddy to merge them — only one set
    # of values wins, which silently breaks the path-specific override.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(self), microphone=(self), display-capture=(self)"
    }

    # LiveKit WebSocket signaling. Clients connect to wss://meet.witysk.org/rtc
    # LiveKit runs with network_mode: host, so Caddy (bridge network) reaches
    # it via host.docker.internal:7880, not via Docker DNS. The livekit-client
    # SDK also appends its own path (/rtc or /rtc/v1) to the serverUrl, so an
    # incoming request looks like /rtc/rtc/v1 — strip our /rtc prefix before
    # forwarding so LiveKit receives the canonical /rtc/v1 path.
    @rtc path /rtc /rtc/*
    handle @rtc {
        uri strip_prefix /rtc
        reverse_proxy host.docker.internal:7880
    }

    # meeting-api (REST + webhook receiver).
    @api path /api/*
    handle @api {
        reverse_proxy meeting-api:8080
    }

    # Recording downloads streamed via meeting-api.
    @rec path /rec/*
    handle @rec {
        reverse_proxy meeting-api:8080
    }

    # /public/<slug> is the view-only stream page and must be embeddable
    # from arbitrary third-party sites. X-Frame-Options is intentionally
    # omitted; CSP uses frame-ancestors * to allow cross-origin embedding.
    handle /public/* {
        header Content-Security-Policy "default-src 'self'; script-src 'self' 'wasm-unsafe-eval' blob: https://cdn.jsdelivr.net https://www.paypal.com https://www.paypalobjects.com; style-src 'self' 'unsafe-inline' https://www.paypalobjects.com; img-src 'self' data: blob: https://storage.googleapis.com https://www.paypal.com https://www.paypalobjects.com https://t.paypal.com; media-src 'self' blob:; connect-src 'self' wss://meet.witysk.org https://one.witysk.org https://cdn.jsdelivr.net https://storage.googleapis.com https://www.paypal.com https://api-m.paypal.com https://api-m.sandbox.paypal.com https://www.sandbox.paypal.com https://t.paypal.com; frame-src https://one.witysk.org https://www.paypal.com https://www.sandbox.paypal.com; worker-src 'self' blob:; frame-ancestors *; base-uri 'self'; form-action 'self'"
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }

    # Live HLS for the TI-TV mobile apps (native Media3/ExoPlayer + AVPlayer,
    # plus any web player). Served from the egress local-storage HLS dir which
    # is mounted read-only at /srv/hls (see docker-compose caddy volumes).
    # `handle_path` strips the /hls prefix so /hls/titv/live.m3u8 maps to
    # /srv/hls/titv/live.m3u8. CORS is open (native players don't send Origin,
    # but a browser HLS player needs it) and caching is disabled so the
    # sliding-window live playlist and its newest segments are always fresh.
    handle_path /hls/* {
        header {
            Access-Control-Allow-Origin *
            Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
            Access-Control-Allow-Headers "Range"
            Cache-Control "no-cache, no-store, must-revalidate"
        }
        # Force correct HLS MIME types — Caddy's Go mime table mislabels `.ts`
        # as text/vnd.trolltech.linguist, which strict web/Safari HLS players
        # reject (native AVPlayer/ExoPlayer infer from the playlist and don't care).
        @m3u8 path *.m3u8
        header @m3u8 Content-Type "application/vnd.apple.mpegurl"
        @ts path *.ts
        header @ts Content-Type "video/mp2t"
        root * /srv/hls
        file_server
    }

    # /egress-layout/* is the custom Web template used by LiveKit Egress.
    # LiveKit's headless Chrome fetches this page with no cookies and
    # passes the LiveKit WS URL as a query param. In this deployment
    # that URL is `ws://host.docker.internal:7880` (LiveKit runs on the
    # host network, egress on the bridge network reaches it via the
    # docker host gateway). The page subsequently connects to that URL
    # via WebSocket, so `connect-src` must allow it — and since the URL
    # is server-controlled and the page is only ever loaded by trusted
    # egress chrome, we relax `connect-src` to `*` here. X-Frame-Options
    # is omitted, consistent with `/public/*`.
    handle /egress-layout/* {
        header Content-Security-Policy "default-src 'self'; script-src 'self' 'wasm-unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; media-src 'self' blob:; connect-src *; worker-src 'self' blob:; frame-ancestors *; base-uri 'self'; form-action 'self'"
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }

    # Frontend SPA fallback — locked-down framing for all other paths.
    # CSP rationale (Phase 12):
    #   - self for scripts/styles bundled by Vite
    #   - wss://meet.witysk.org for LiveKit signaling
    #   - blob: for the MediaPipe/track-processors worker and video blobs
    #   - https://one.witysk.org for any future SSO bootstrap iframe
    #   'unsafe-inline' in style-src is required by @livekit/components-styles.
    #   'wasm-unsafe-eval' is required by @livekit/track-processors (MediaPipe).
    #   frame-src https://one.witysk.org is required for the SSO bootstrap
    #   iframe that reads one.witysk.org's localStorage and postMessages the
    #   access_token back. See one-witysk-integration/README.md.
    #   @livekit/track-processors loads MediaPipe wasm + tflite models from
    #   cdn.jsdelivr.net at runtime; without this allowance, virtual
    #   backgrounds silently fail with a CSP violation.
    handle {
        header X-Frame-Options "DENY"
        header Content-Security-Policy "default-src 'self'; script-src 'self' 'wasm-unsafe-eval' blob: https://cdn.jsdelivr.net https://www.paypal.com https://www.paypalobjects.com; style-src 'self' 'unsafe-inline' https://www.paypalobjects.com; img-src 'self' data: blob: https://storage.googleapis.com https://www.paypal.com https://www.paypalobjects.com https://t.paypal.com; media-src 'self' blob:; connect-src 'self' wss://meet.witysk.org https://one.witysk.org https://cdn.jsdelivr.net https://storage.googleapis.com https://www.paypal.com https://api-m.paypal.com https://api-m.sandbox.paypal.com https://www.sandbox.paypal.com https://t.paypal.com; frame-src https://one.witysk.org https://www.paypal.com https://www.sandbox.paypal.com; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }
}
